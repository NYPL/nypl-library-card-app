# 1. Declare the ARG before FROM so it can be used in the image name
ARG PW_VERSION=1.58.2

# 2. Use the ARG to pull the correct image
FROM mcr.microsoft.com/playwright:v${PW_VERSION}-noble

# 3. Re-declare the ARG inside the stage if you need to use it in RUN/ENV commands
ARG PW_VERSION

# Environment setup
ENV NODE_ENV=test
ENV NEXT_TELEMETRY_DISABLED=1
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 

WORKDIR /app

# Install dependencies (utilizing Docker layer caching)
COPY package*.json ./
RUN npm ci --legacy-peer-deps

# Copy the rest of the application
COPY . .

# Default command
CMD ["npx", "playwright", "test"]