{
  "name": "nypl-library-card-app",
  "version": "1.4.3",
  "description": "NYPL Get A Library Card App",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p $PORT",
    "local-prod": "next build && NODE_ENV=production node https-server.js",
    "eb:start": "npm run build && npm run start",
    "test": "jest",
    "test:clear": "jest --clearCache",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "playwright": "npx playwright test",
    "playwright:qa": "PLAYWRIGHT_BASE_URL=https://qa-www.nypl.org npx playwright test",
    "prepare": "husky install",
    "lint": "eslint --fix"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NYPL/nypl-library-card-app"
  },
  "keywords": [
    "react",
    "next",
    "es6",
    "sass"
  ],
  "author": "NYPL Digital",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/issues"
  },
  "dependencies": {
    "@nypl/design-system-react-components": "4.1.6",
    "axios": "1.7.2",
    "bwip-js": "2.0.10",
    "cookie": "^1.0.2",
    "cors": "2.8.5",
    "lodash": "4.17.21",
    "moment": "2.30.1",
    "newrelic": "^13.0.0",
    "next": "15.5.9",
    "next-i18next": "11.3.0",
    "qs": "6.10.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.62.0",
    "request-ip": "3.3.0",
    "sass": "1.26.9",
    "validator": "13.0.0",
    "winston": "3.3.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.36.0",
    "@next/eslint-plugin-next": "^15.5.4",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-hooks": "5.0.3",
    "@types/jest": "29.5.12",
    "@types/jest-axe": "^3.5.9",
    "@types/newrelic": "^9.14.8",
    "@types/node": "14.0.14",
    "@types/react": "^18",
    "@types/sanitize-html": "2.16.1",
    "babel-jest": "^30.4.1",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "husky": "9.0.11",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "29.7.0",
    "lint-staged": "10.1.3",
    "next-router-mock": "^0.9.13",
    "prettier": "^3.6.2",
    "sanitize-html": "2.17.3",
    "typescript": "4.9.5",
    "typescript-eslint": "^8.45.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --cache --fix",
    "*.{js,jsx,ts,tsx,css,md}": "prettier --write"
  }
}
